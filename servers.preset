# https://systemd.io/PRESET/
# If multiple lines apply to a unit name, the first matching one takes precedence over all others.
enable caddy.service
enable systemd-networkd.service
enable sshd.service
enable bootc-fetch-apply-updates.timer
enable set_hostname.service

enable var-www-lists.gluster.org.mount
enable var-www-download.gluster.org.mount
